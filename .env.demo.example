# Copy to `.env.demo` (gitignored) for demo export/import scripts.
# See docs/DEMO_ENVIRONMENT.md

# Source: production or staging Postgres (read-only for export)
SOURCE_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Target: empty or disposable Neon branch / Postgres for the demo deployment only
DEMO_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DEMO_DB?sslmode=require"

# Optional: only if you intentionally import into the same URL as DATABASE_URL (dangerous)
# DEMO_ALLOW_IMPORT_TO_PRIMARY_DATABASE=yes
